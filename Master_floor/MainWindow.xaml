<Window x:Class="Master_floor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master Floor - Управление партнерами" 
        Height="500" Width="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Список партнеров -->
        <ListView x:Name="listPartner" Grid.Row="0" Grid.ColumnSpan="2" Margin="10" 
                  MouseDoubleClick="listPartner_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="1" Margin="5" Padding="10" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Тип_партнера}" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                            <TextBlock Text="{Binding Наименование_партнера}" FontSize="14" FontWeight="Bold" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="{Binding Скидка}" Foreground="Green" FontWeight="Bold" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right"/>

                            <TextBlock Text="{Binding Директор}" Grid.Row="1" Grid.ColumnSpan="3" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding Телефон_партнера}" Grid.Row="2" Grid.ColumnSpan="3"/>
                            <TextBlock Text="{Binding Рейтинг, StringFormat='Рейтинг: {0}'}" Grid.Row="3" Grid.ColumnSpan="3"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Кнопки -->
        <Button x:Name="btnAddPartner" Content="➕ Добавить партнера" Grid.Row="1" Margin="20" 
                Click="btnAddPartner_Click" FontSize="14" Height="40"/>

        <Button x:Name="btnProduct" Content="📊 История продаж" Grid.Column="1" Grid.Row="1" Margin="20" 
                Click="btnProduct_Click" FontSize="14" Height="40"/>
    </Grid>
</Window>